# Backend proxy settings for Dify Chat API
DIFY_API_URL=https://your-dify-host/v1/chat-messages
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# Authelia remote-user allowed to access the admin backend.
ADMIN_REMOTE_USER=admin

# Invoice backend (used by /invoice-proxy). Defaults to 127.0.0.1:8082 if unset.
INVOICE_HOST=127.0.0.1
INVOICE_PORT=8082
